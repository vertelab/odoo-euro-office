<templates xml:space="preserve">
    <t t-inherit="mail.AttachmentList" t-inherit-mode="extension" owl="1">
    <xpath expr="//div[hasclass('o-mail-AttachmentButtons')]" position="inside">
      <button
        t-if="euro_officeCanOpen(attachment)"
        t-on-click.stop="() => this.openEuroOffice(attachment)"
        class="btn bg-500 w-100 h-100 o-p-1_5 d-flex justify-content-center align-items-center shadow-sm ms-2"
        title="Open in Euro-Office"
      >
        <img src="/euro_office_odoo/static/svg/edit.svg" role="img" width="16" height="16" />
      </button>
    </xpath>
  </t>
</templates>
