<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Euro-Office button in DMS file form header -->
    <record id="view_dms_file_form_euro_office" model="ir.ui.view">
        <field name="name">dms.file.form.euro_office</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button
                    name="open_in_euro_office_action"
                    type="object"
                    string="Open in Euro-Office"
                    class="btn-primary"
                    invisible="not can_open_in_euro_office"
                />
            </xpath>
        </field>
    </record>

    <!-- Server action: "Open in Euro-Office" in Action menu -->
    <record id="action_dms_file_open_euro_office" model="ir.actions.server">
        <field name="name">Open in Euro-Office</field>
        <field name="model_id" ref="dms.model_dms_file"/>
        <field name="binding_model_id" ref="dms.model_dms_file"/>
        <field name="binding_view_types">list,kanban,form</field>
        <field name="state">code</field>
        <field name="code">
            action = records.open_in_euro_office_action()
        </field>
    </record>
</odoo>
